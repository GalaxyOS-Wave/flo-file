{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project managed by the freelancer.",
      "type": "object",
      "properties": {
        "client_name": { "type": "string" },
        "project_name": { "type": "string" },
        "amount_due": { "type": "number" },
        "is_paid": { "type": "boolean" },
        "file_name": { "type": "string" },
        "file_size": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "owner_id": { "type": "string" },
        "client_id": { "type": "string" }
      },
      "required": ["client_name", "project_name", "amount_due", "is_paid", "created_at", "owner_id"]
    },
    "ClientRecord": {
      "title": "ClientRecord",
      "description": "A client record.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "company_name": { "type": "string" },
        "phone": { "type": "string" },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "owner_id": { "type": "string" }
      },
      "required": ["name", "email", "created_at", "owner_id"]                
    },
    "Invoice": {
      "title": "Invoice",
      "description": "An invoice for a project.",
      "type": "object",
      "properties": {
        "invoice_number": { "type": "string" },
        "client_id": { "type": "string" },
        "client_name": { "type": "string" },
        "project_id": { "type": "string" },
        "issue_date": { "type": "string" },
        "due_date": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid", "overdue"] },
        "owner_id": { "type": "string" }
      },
      "required": ["invoice_number", "client_id", "status", "owner_id"]
    },
    "Message": {
      "title": "Message",
      "description": "A project chat message.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "attachmentUrl": { "type": "string" },
        "messageType": { "type": "string" }
      },
      "required": ["projectId", "senderId", "message", "timestamp", "messageType"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "A collection of projects."
    },
    "clients": {
      "schema": "ClientRecord",
      "description": "A collection of clients."
    },
    "invoices": {
      "schema": "Invoice",
      "description": "A collection of invoices."
    },
    "messages": {
      "schema": "Message",
      "description": "A collection of project messages."
    }
  }
}
